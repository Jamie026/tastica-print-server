{
    "name": "tastica-print-agent",
    "version": "1.0.0",
    "description": "Agente de impresión automática para Tastica",
    "main": "main.js",
    "author": "Tastica",
    "scripts": {
        "start": "electron .",
        "dist:win": "electron-builder --win",
        "dist:mac": "electron-builder --mac",
        "dist:linux": "electron-builder --linux",
        "dist:all": "electron-builder --win --mac --linux"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "escpos": "^3.0.0-alpha",
        "escpos-network": "^3.0.0-alpha"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0"
    },
    "build": {
        "appId": "com.tastica.printagent",
        "productName": "Tastica Print Agent",
        "icon": "assets/icon",
        "afterPack": "./afterPack.js",
        "files": [
            "main.js",
            "preload.js",
            "renderer.html",
            "assets/**"
        ],
        "win": {
            "target": "nsis",
            "icon": "assets/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "assets/icon.icns",
            "category": "public.app-category.utilities"
        },
        "linux": {
            "target": "AppImage",
            "icon": "assets/icon.png",
            "category": "Utility"
        },
        "nsis": {
            "oneClick": true,
            "installerLanguages": [
                "es_ES"
            ],
            "language": "3082"
        }
    }
}
